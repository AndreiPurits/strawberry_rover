[Unit]
Description=Strawberry Rover - Curation UI (Flask)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/andrei/project/strawberry_rover_ws
Environment=PYTHONUNBUFFERED=1
Environment=CURATION_UI_HOST=0.0.0.0
Environment=CURATION_UI_PORT=7860
ExecStart=/usr/bin/env python3 /home/andrei/project/strawberry_rover_ws/scripts/curation_ui.py
Restart=on-failure
RestartSec=1
StartLimitIntervalSec=0

[Install]
WantedBy=default.target
