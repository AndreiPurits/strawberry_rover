<?xml version="1.0"?>
<robot name="strawberry_rover">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 1.1" rpy="0 0 0"/>
      <geometry>
        <box size="1.3 0.2 0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <link name="left_arch_leg_link">
    <visual>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <geometry>
        <box size="1.3 0.08 1.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="left_arch_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_arch_leg_link"/>
    <origin xyz="0.0 0.56 0.0" rpy="0 0 0"/>
  </joint>

  <link name="right_arch_leg_link">
    <visual>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <geometry>
        <box size="1.3 0.08 1.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="right_arch_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_arch_leg_link"/>
    <origin xyz="0.0 -0.56 0.0" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.35 0.0 1.0" rpy="0 0 0"/>
  </joint>

  <link name="camera_front_link">
    <visual>
      <geometry>
        <box size="0.08 0.05 0.04"/>
      </geometry>
      <material name="green">
        <color rgba="0.1 0.8 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="camera_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front_link"/>
    <origin xyz="0.45 0.0 0.85" rpy="0 -0.261799 0"/>
  </joint>

  <link name="stereo_link">
    <visual>
      <geometry>
        <box size="0.12 0.04 0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="stereo_joint" type="fixed">
    <parent link="base_link"/>
    <child link="stereo_link"/>
    <origin xyz="0.40 0.0 0.80" rpy="0 0 0"/>
  </joint>

  <link name="bottom_rgb_camera_link">
    <visual>
      <geometry>
        <box size="0.07 0.05 0.05"/>
      </geometry>
      <material name="orange">
        <color rgba="0.95 0.55 0.15 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="bottom_rgb_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bottom_rgb_camera_link"/>
    <origin xyz="0.0 0.0 0.55" rpy="0 -1.5708 0"/>
  </joint>

</robot>
