# Один раз: cp ops/axm-monitor/scripts/pc_deploy.env.example ~/pc_deploy.env
# PC (Git Bash) или Orin — оба могут вызывать deploy_site_from_pc.sh

# Host из ~/.ssh/config (Orin + PC)
AXM_SSH_HOST=geekom_vlad

# Git Bash path к hub на Windows VPS (user redro)
AXM_VPS_HUB_DIR=/c/Users/redro/project/ops/axm-monitor

# Git Bash на VPS (Windows path — не /c/... ; WSL bash при SSH сломан)
AXM_VPS_BASH=C:\Program Files\Git\bin\bash.exe
