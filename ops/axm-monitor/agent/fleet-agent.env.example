# Copy to ~/.config/axm/fleet-agent.env on Orin (chmod 600). Do not commit.

AXM_HUB_URL=https://rover.axm.tech
AXM_ROVER_ID=rover-01
AXM_ROVER_TOKEN=REPLACE_WITH_TOKEN_FROM_VPS_.env
AXM_ROVER_NAME=Orin-01
AXM_LOCAL_WEB=http://127.0.0.1:8080
MEGA_PORT=/dev/ttyUSB0
# Hub camera relay (Orin → VPS). Stereo at low FPS to save Wi‑Fi.
AXM_HUB_CAMERA_FPS=12
AXM_HUB_STEREO=true
AXM_HUB_STEREO_FPS=10
# RoArm-M3 on local LAN (Orin proxies to hub /roarm — ESP not exposed to internet)
ROARM_ENABLED=true
ROARM_IP=192.168.3.22
ROARM_MOVE_TIMEOUT_S=30
ROARM_JOINT_MOVE_TIMEOUT_S=8
ROARM_STAGED_PAUSE_S=0.9
ROARM_STAGED_JOINT_TIMEOUT_S=12
# Grip close: T:112 max torque + repeated T:106 (pads/blades)
ROARM_GRIP_CLOSE_FORCE=1
ROARM_GRIP_CLOSE_RAD=3.14
ROARM_GRIP_TORQUE_G=1000
ROARM_GRIP_CLOSE_ACC=50
ROARM_GRIP_CLOSE_PULSES=1
ROARM_GRIP_PULSE_DELAY_S=0.2
ROARM_GRIP_RPC_TIMEOUT_S=20
ROARM_PROBE_INTERVAL_S=15

RTK_PORT=/dev/ttyACM0
RTK_BAUD=38400
# gps = standard GNSS. rtk = enable NTRIP below.
AXM_GNSS_MODE=gps

# NTRIP caster → RTCM3 (only when AXM_GNSS_MODE=rtk)
NTRIP_ENABLED=false
NTRIP_HOST=caster.example.com
NTRIP_PORT=2101
NTRIP_MOUNTPOINT=MOUNT
NTRIP_USER=
NTRIP_PASSWORD=
# VRS casters: reconnect with fresh GGA every N seconds once GPS fix exists
NTRIP_GGA_INTERVAL_S=10
NTRIP_RECONNECT_S=5
NTRIP_TLS=false
# Rough position for VRS before first GPS fix (e.g. last known field coords)
# NTRIP_APPROX_LAT=55.6086
# NTRIP_APPROX_LON=37.6056
