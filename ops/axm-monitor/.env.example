# Copy to ops/axm-monitor/.env on the VPS and fill secrets.

# Dashboard login (change before production!)
AXM_ADMIN_USER=admin
AXM_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: bcrypt hash instead of plain password
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
# AXM_ADMIN_PASSWORD_HASH=

# Agent tokens: rover_id -> secret (must match Orin AXM_ROVER_TOKEN)
AXM_AGENT_TOKENS={"rover-01":"GENERATE_LONG_RANDOM_TOKEN_1","rover-02":"GENERATE_LONG_RANDOM_TOKEN_2"}

# Alternative per-rover env vars:
# ROVER_01_TOKEN=...
# ROVER_02_TOKEN=...
