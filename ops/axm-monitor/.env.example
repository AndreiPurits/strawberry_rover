# Copy to ops/axm-monitor/.env on the VPS and fill secrets.

# Dashboard login (change before production!)
AXM_ADMIN_USER=admin
AXM_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: per-user passwords (bcrypt hashes). If unset, any username works with AXM_ADMIN_PASSWORD.
# AXM_USERS_JSON={"admin":"$2b$12$...","vlad":"$2b$12$..."}
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
# AXM_ADMIN_PASSWORD_HASH=

# Optional: stable session signing (defaults to AXM_ADMIN_PASSWORD_HASH / AXM_ADMIN_PASSWORD)
# AXM_SESSION_SECRET=long_random_string_same_across_redeploys

# Agent tokens: rover_id -> secret (must match Orin AXM_ROVER_TOKEN)
AXM_AGENT_TOKENS={"rover-01":"GENERATE_LONG_RANDOM_TOKEN_1","rover-02":"GENERATE_LONG_RANDOM_TOKEN_2"}

# WebRTC TURN (coturn on VPS) — optional, STUN-only works on some networks
# AXM_STUN_URL=stun:stun.l.google.com:19302
# AXM_TURN_URL=turn:rover.axm.tech:3478?transport=udp
# AXM_TURN_USER=axm
# AXM_TURN_PASS=CHANGE_ME_TURN_SECRET

# Alternative per-rover env vars:
# ROVER_01_TOKEN=...
# ROVER_02_TOKEN=...
